{
	"name": "twentytwentyfive",
	"version": "1.5.0",
	"description": "Default WP Theme",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"WordPress",
		"Theme"
	],
	"bugs": {
		"url": "https://core.trac.wordpress.org/"
	},
	"homepage": "https://wordpress.org/themes/twentytwentyfive/",
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"devDependencies": {
		"@wordpress/browserslist-config": "^6.34.0",
		"cssnano": "^7.1.2",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"postcss-import": "^16.1.0",
		"postcss-preset-env": "^10.1.0",
		"webpack": "^5.98.0",
		"webpack-cli": "^6.0.1"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"scripts": {
		"start": "npm run build:styles && npm run build:js",
		"build": "npm run build:styles && npm run build:js",
		"build:js": "webpack --mode=production",
		"build:styles": "NODE_ENV=production postcss resources/styles/style.css -o public/style.css",
		"watch:styles": "postcss resources/styles/style.css -o public/style.css --watch"
	}
}
